@page "/chat"
@rendermode InteractiveServer
@using System.Collections.ObjectModel
@using IndustrialAICopilot.Application.Interfaces
@inject IJSRuntime JSRuntime
@inject IQuestionResponder QuestionResponder

<div class="chat-container">
    <div class="chat-card">
        
        @* 標題區塊 *@
        <header class="chat-header">
            <div class="chat-header-info">
                <h2 class="chat-header-title">💬 AI智能問答</h2>
                <div class="chat-header-content">
                    <p>即時檢索企業知識，為現場設備故障提供精準的排除對策。</p>
                </div>
            </div>
        </header>

        @* 訊息顯示區塊 *@
        <div class="chat-body">
            @if (!_chatMessages.Any())
            {
                <div class="chat-body-empty-state">
                    <div class="chat-body-empty-icon">👩‍🏫</div>
                    <p>今天有什麼可以幫您的嗎？</p>
                    <small>您可以詢問關於設備維護、操作指南或系統設定的問題。</small>
                </div>
            }

            @foreach (var msg in _chatMessages)
            {
                <div class="msg-wrapper @(msg.IsUser ? "user" : "ai")">
                    <div class="msg-bubble">
                        @msg.Content
                    </div>
                    <div class="msg-meta">
                        <span class="msg-sender">@(msg.IsUser ? "您" : "AI 助理")</span>
                        <span class="msg-time">@msg.Timestamp.ToString("HH:mm")</span>
                    </div>
                </div>
            }

            @if (_isThinking)
            {
                <div class="msg-wrapper ai">
                    <div class="msg-bubble thinking">
                        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                    </div>
                </div>
            }
        </div>

        @* 底部輸入區塊 *@
        <footer class="chat-footer">
            <div class="input-wrapper">
                <input type="text" class="chat-input" placeholder="請輸入您的問題..."
                        @bind="_currentInput" @bind:event="oninput" @onkeyup="HandleKeyUp" disabled="@_isThinking" />
                <button class="btn-send @(string.IsNullOrWhiteSpace(_currentInput) || _isThinking ? "disabled" : "")" 
                        @onclick="SendMessage" 
                        disabled="@(string.IsNullOrWhiteSpace(_currentInput) || _isThinking)">
                    <span>🚀 傳送</span>
                </button>
            </div>
        </footer>

    </div>
</div>

<style>
    /* 佈局與容器 */
    .chat-container { display: flex; flex-direction: column; min-height: calc(100vh - 80px); padding: 30px; background: #0f172a; max-width: 1200px; margin: 0 auto; width: 100%;  }
    .chat-card { flex: 1; background: #1e293b; border-radius: 24px; overflow: hidden; border: 1px solid #334155; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3); display: flex; flex-direction: column; }

    /* 標題區塊 */
    .chat-header { padding: 30px 40px; border-bottom: 1px solid #334155; background: rgba(15, 23, 42, 0.4); }
    .chat-header-title { color: white; margin: 0; font-size: 1.5rem; font-weight: 700; }
    .chat-header-content { margin-top: 6px; display: flex; flex-direction: column; gap: 4px; }
    .chat-header-content p { margin: 0; color: #94a3b8; font-size: 0.95rem; }
    .chat-header-content small { color: #64748b; font-size: 0.8rem; }
    .chat-header-content strong { color: #3b82f6; }

    /* 訊息顯示區塊 */
    .chat-body { flex: 1; padding: 30px 40px; display: flex; flex-direction: column; gap: 24px; background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.03), transparent); }
    .chat-body-empty-state { margin: auto; text-align: center; color: #64748b; }
    .chat-body-empty-icon { font-size: 3rem; margin-bottom: 10px; opacity: 0.5; }
    .chat-body-empty-state p { color: #f1f5f9; font-weight: 600; margin-bottom: 4px; }

    .msg-wrapper { display: flex; flex-direction: column; max-width: 80%; }
    .msg-wrapper.user { align-self: flex-end; align-items: flex-end; }
    .msg-wrapper.ai { align-self: flex-start; align-items: flex-start; }

    .msg-bubble { padding: 14px 20px; border-radius: 18px; font-size: 1rem; line-height: 1.6; position: relative; transition: 0.2s; }
    .user .msg-bubble { background: #3b82f6; color: white; border-bottom-right-radius: 4px; box-shadow: 0 4px 15px rgba(59, 130, 246, 0.2); }
    .ai .msg-bubble { background: #334155; color: #f1f5f9; border-bottom-left-radius: 4px; border: 1px solid #475569; }

    .msg-meta { margin-top: 6px; display: flex; gap: 8px; font-size: 0.75rem; color: #64748b; padding: 0 4px; }

    /* 底部輸入區塊 */
    .chat-footer { padding: 24px 40px; background: rgba(15, 23, 42, 0.6); border-top: 1px solid #334155; }
    .input-wrapper { display: flex; gap: 12px; }
    .chat-input { flex: 1; background: #0f172a; border: 1px solid #334155; color: #f1f5f9; padding: 14px 20px; border-radius: 12px; outline: none; transition: 0.2s; }
    .chat-input:focus { border-color: #3b82f6; background: #131c2e; }
    
    .btn-send { background: #3b82f6; color: white; padding: 0 24px; border-radius: 12px; font-weight: 600; border: none; cursor: pointer; transition: 0.3s; }
    .btn-send:hover:not(.disabled) { background: #2563eb; transform: translateY(-2px); }
    .btn-send.disabled { opacity: 0.5; cursor: not-allowed; filter: grayscale(1); }

    /* 思考動畫 */
    .thinking { display: flex; gap: 4px; padding: 12px 18px; }
    .dot { width: 6px; height: 6px; background: #94a3b8; border-radius: 50%; animation: bounce 1.4s infinite; }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes bounce { 0%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-6px); } }
</style>

@code {
    private string _currentInput = "";
    private bool _isThinking = false;
    private List<ChatMessage> _chatMessages = new();

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_currentInput) || _isThinking)
            return;

        var userQuery = _currentInput;
        _currentInput = "";

        _chatMessages.Add(new ChatMessage { 
            Content = userQuery, 
            IsUser = true, 
            Timestamp = DateTime.Now 
        });

        _isThinking = true;
        StateHasChanged();
        await ScrollToBottom(); 

        try 
        {
            var replyText = await QuestionResponder.RespondAsync(userQuery);

            _chatMessages.Add(new ChatMessage { 
                Content = replyText, 
                IsUser = false, 
                Timestamp = DateTime.Now 
            });

            _isThinking = false;
            StateHasChanged();
            await ScrollToBottom();
        }
        catch (Exception ex)
        {
            _chatMessages.Add(new ChatMessage { 
                Content = "抱歉，目前似乎有點問題，請稍後再試。 (" + ex.Message + ")", 
                IsUser = false, 
                Timestamp = DateTime.Now 
            });

            _isThinking = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await ScrollToBottom();
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100); 
        await JSRuntime.InvokeVoidAsync("eval", @"
            var mainElem = document.querySelector('main');
            if (mainElem) {
                mainElem.scrollTo({
                    top: mainElem.scrollHeight,
                    behavior: 'smooth'
                });
            }
        ");
    }

    class ChatMessage
    {
        public string Content { get; set; } = "";
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; }
    }
}